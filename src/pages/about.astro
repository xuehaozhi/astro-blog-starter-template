---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { SITE_TITLE } from '../consts';

const pageTitle = `关于我们 - ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description="关于 MineForum 论坛" />
	</head>
	<body>
		<Header />
		<div class="container">
			<Breadcrumb
				items={[
					{ label: '关于我们' },
				]}
			/>

			<div class="main-layout">
				<div class="main-content">
					<div class="card">
						<div class="card-header">
							📖 关于我们
						</div>
						<div class="card-body">
							<h2 class="section-title">欢迎来到 MineForum！</h2>
							<p>
								MineForum 是一个由 Minecraft 爱好者组成的中文社区论坛。我们致力于为广大玩家提供一个优质的交流平台，
								分享游戏资源、交流游戏心得、结识志同道合的朋友。
							</p>

							<h3 class="section-title" style="font-size: 16px; margin-top: 24px;">🎯 我们的使命</h3>
							<p>
								打造最优质的 Minecraft 中文社区，让每一位玩家都能在这里找到属于自己的乐趣。
							</p>

							<h3 class="section-title" style="font-size: 16px; margin-top: 24px;">📋 论坛特色</h3>
							<ul style="padding-left: 20px; line-height: 2;">
								<li><strong>丰富的资源分享</strong> - 模组、材质包、地图、整合包应有尽有</li>
								<li><strong>活跃的社区氛围</strong> - 每日都有新的讨论和分享</li>
								<li><strong>完善的积分系统</strong> - 参与互动获取积分，兑换各种奖励</li>
								<li><strong>专业的管理团队</strong> - 为社区秩序保驾护航</li>
								<li><strong>多元的内容板块</strong> - 满足不同玩家的兴趣需求</li>
							</ul>

							<h3 class="section-title" style="font-size: 16px; margin-top: 24px;">🏗️ 技术栈</h3>
							<p>
								本论坛基于以下技术构建：
							</p>
							<ul style="padding-left: 20px; line-height: 2;">
								<li><strong>Astro</strong> - 现代化的前端框架</li>
								<li><strong>Cloudflare Workers</strong> - 高性能的边缘计算平台</li>
								<li><strong>Cloudflare D1</strong> - 分布式 SQL 数据库</li>
								<li><strong>TypeScript</strong> - 类型安全的 JavaScript</li>
							</ul>

							<h3 class="section-title" style="font-size: 16px; margin-top: 24px;">📬 联系我们</h3>
							<p>
								如有任何问题或建议，欢迎通过以下方式联系我们：
							</p>
							<ul style="padding-left: 20px; line-height: 2;">
								<li>论坛事务：前往「站务管理」板块发帖</li>
								<li>意见反馈：在「意见反馈」板块提交</li>
							</ul>
						</div>
					</div>
				</div>
				<Sidebar />
			</div>
		</div>
		<Footer />
	</body>
</html>
