---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import Sidebar from '../../components/Sidebar.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE_TITLE } from '../../consts';
import { initDB } from '../../lib/init-db';
import { getForumById, getCategoryById, getThreadsByForum } from '../../lib/db';
import { formatNumber, formatDate } from '../../lib/utils';

const runtime = Astro.locals.runtime;
await initDB(runtime);

const forumId = parseInt(Astro.params.id);
const page = parseInt(Astro.url.searchParams.get('page') || '1');
const pageSize = 20;

const forum = await getForumById(forumId);

if (!forum) {
	return Astro.redirect('/404');
}

const category = await getCategoryById(forum.category_id);
const { threads, total } = await getThreadsByForum(forumId, page, pageSize);
const totalPages = Math.ceil(total / pageSize);

const pageTitle = `${forum.name} - ${SITE_TITLE}`;
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={pageTitle} description={forum.description || SITE_TITLE} />
	</head>
	<body>
		<Header />
		<div class="container">
			<Breadcrumb
				items={[
					category ? { label: category.name, href: '#' } : null,
					{ label: forum.name },
				].filter(Boolean)}
			/>

			<div class="main-layout">
				<div class="main-content">
					<div class="forum-header">
						<div class="forum-header-info">
						<h1>{forum.icon && <span style="margin-right: 8px;">{forum.icon}</span>}{forum.name}</h1>
						<p>{forum.description || '暂无描述'}</p>
					</div>
						<a href={`/post/new?forum_id=${forum.id}`} class="btn btn-primary">
							✏️ 发帖
						</a>
					</div>

					<div class="thread-list">
						{threads.length > 0 ? (
							threads.map((thread) => (
								<div class={`thread-item ${thread.is_pinned ? 'pinned' : ''}`}>
									<div class="thread-icon">
										{thread.is_pinned ? '📌' : '📄'}
									</div>
									<div class="thread-main">
										<div class="thread-title">
											<a href={`/thread/${thread.id}`}>
												{thread.is_pinned && <span style="color: var(--danger); margin-right: 4px;">[置顶]</span>}
												{thread.title}
											</a>
										</div>
										<div class="thread-meta">
											<span>
												作者: <a href="#">{thread.username}</a>
											</span>
											<span>{formatDate(thread.created_at)}</span>
										</div>
									</div>
									<div class="thread-stats">
										<div class="thread-stat">
											<div class="thread-stat-num">{formatNumber(thread.reply_count)}</div>
											<div class="thread-stat-label">回复</div>
										</div>
										<div class="thread-stat">
											<div class="thread-stat-num">{formatNumber(thread.view_count)}</div>
											<div class="thread-stat-label">浏览</div>
										</div>
									</div>
									<div class="thread-author">
										<div class="avatar avatar-sm">
											<img src={thread.avatar || 'https://api.dicebear.com/7.x/pixel-art/svg?seed=default'} alt={thread.username} />
										</div>
										<div class="thread-author-info">
											<div class="thread-author-name">{thread.last_post_username || thread.username}</div>
											<div class="thread-author-time">{formatDate(thread.last_post_at)}</div>
										</div>
									</div>
								</div>
							))
						) : (
							<div class="empty-state">
								<div class="empty-icon">📭</div>
								<div class="empty-text">暂无主题，快来发第一个帖子吧！</div>
							</div>
						)}
					</div>

					<Pagination currentPage={page} totalPages={totalPages} baseUrl={`/forum/${forumId}`} />
				</div>
				<Sidebar />
			</div>
		</div>
		<Footer />
	</body>
</html>
