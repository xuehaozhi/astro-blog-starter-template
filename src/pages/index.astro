---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { initDB } from '../lib/init-db';
import { getCategoriesWithForums } from '../lib/db';
import { formatNumber, formatDate } from '../lib/utils';

const runtime = Astro.locals.runtime;
await initDB(runtime);

const categories = await getCategoriesWithForums();
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<div class="container">
			<div class="main-layout">
				<div class="main-content">
					{categories.map((category) => (
						<div class="category-block">
							<div class="category-header">
								<div class="category-title">
									<span class="category-icon">{category.icon || '📁'}</span>
									<span>{category.name}</span>
								</div>
							</div>
							<div class="forum-list">
								{category.forums.map((forum) => (
									<div class="forum-item">
										<div class="forum-icon">
											{forum.icon || '💬'}
										</div>
										<div class="forum-info">
											<div class="forum-name">
												<a href={`/forum/${forum.id}`}>{forum.name}</a>
											</div>
											<div class="forum-desc">{forum.description || '暂无描述'}</div>
										</div>
										<div class="forum-stats">
											<div class="forum-stat-num">{formatNumber(forum.thread_count)}</div>
											<div class="forum-stat-label">主题</div>
										</div>
										<div class="forum-stats">
											<div class="forum-stat-num">{formatNumber(forum.post_count)}</div>
											<div class="forum-stat-label">帖子</div>
										</div>
										<div class="forum-lastpost">
											<div class="lastpost-title">
												<a href="#">最新帖子...</a>
											</div>
											<div class="lastpost-meta">
												{forum.last_post_at ? formatDate(forum.last_post_at) : '暂无帖子'}
											</div>
										</div>
									</div>
								))}
								{category.forums.length === 0 && (
									<div class="empty-state" style="padding: 24px;">
										<div class="empty-icon">📭</div>
										<div class="empty-text">暂无版块</div>
									</div>
								)}
							</div>
						</div>
					))}

					{categories.length === 0 && (
						<div class="card">
							<div class="card-body">
								<div class="empty-state">
									<div class="empty-icon">🔧</div>
									<div class="empty-text">论坛正在建设中...</div>
								</div>
							</div>
						</div>
					)}
				</div>
				<Sidebar />
			</div>
		</div>
		<Footer />
	</body>
</html>
